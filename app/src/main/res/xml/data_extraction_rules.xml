<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up user preferences, theme, and search history/favorites. -->
        <include domain="sharedpref" path="synapse_prefs"/>
    </cloud-backup>
    <device-transfer>
        <!-- Restore all user data when moving to a new device. -->
        <include domain="sharedpref" path="synapse_prefs"/>
    </device-transfer>
</data-extraction-rules>