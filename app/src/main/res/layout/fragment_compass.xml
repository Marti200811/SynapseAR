<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp"
    android:paddingTop="8dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/accent_cyan"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Botón configuración ⚙ -->
    <TextView
        android:id="@+id/btnSettings"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="⚙"
        android:textSize="20sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:background="@null"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/modeBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_horizontal"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintEnd_toStartOf="@id/btnSettings"
        android:layout_marginEnd="6dp"/>

    <!-- Fila de botones: tipo de antena + satélite -->
    <LinearLayout
        android:id="@+id/btnRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSelectAntenna"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/btn_antenna"
            android:textSize="12sp"
            android:textColor="@color/bg_deep"
            android:backgroundTint="@color/accent_amber"/>

        <Button
            android:id="@+id/btnSelectSatellite"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/select_satellite"
            android:textSize="12sp"
            android:textColor="@color/bg_deep"
            android:backgroundTint="@color/accent_cyan"/>

    </LinearLayout>

    <!-- Satélite seleccionado -->
    <TextView
        android:id="@+id/tvSelectedSat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="@color/accent_amber"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/btnRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.example.ar.ui.compass.CompassView
        android:id="@+id/compass"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedSat"
        app:layout_constraintBottom_toTopOf="@id/infoPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/infoPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_panel"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Azimut -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bearing_to_target"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/txtBearing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/accent_cyan"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Elevación (nuevo) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elevation_label"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/txtElevation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/accent_red"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Distancia -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/distance_to_target"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/txtDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/accent_amber"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
