<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- ── Top bar ── -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/accent_cyan"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Botón configuración circular -->
    <TextView
        android:id="@+id/btnSettings"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="⚙"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:background="@drawable/bg_circle_btn"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Badge de modo (VERTICAL / HORIZONTAL) -->
    <TextView
        android:id="@+id/modeBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_horizontal"
        android:textColor="@color/accent_cyan"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:background="@drawable/bg_mode_badge"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/btnSettings"
        app:layout_constraintBottom_toBottomOf="@id/btnSettings"
        app:layout_constraintEnd_toStartOf="@id/btnSettings"/>

    <!-- ── Fila de botones: tipo de antena + satélite ── -->
    <LinearLayout
        android:id="@+id/btnRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSelectAntenna"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_antenna"
            android:textSize="11sp"
            android:textColor="@color/accent_amber"
            app:strokeColor="@color/accent_amber"
            app:strokeWidth="1dp"
            app:cornerRadius="20dp"
            android:backgroundTint="@android:color/transparent"/>

        <Button
            android:id="@+id/btnSelectSatellite"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/select_satellite"
            android:textSize="11sp"
            android:textColor="@color/accent_cyan"
            app:strokeColor="@color/accent_cyan"
            app:strokeWidth="1dp"
            app:cornerRadius="20dp"
            android:backgroundTint="@android:color/transparent"/>

    </LinearLayout>

    <!-- ── Satélite seleccionado (chip) ── -->
    <TextView
        android:id="@+id/tvSelectedSat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text=""
        android:textColor="@color/accent_cyan"
        android:textSize="12sp"
        android:gravity="center"
        android:background="@drawable/bg_sat_chip"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:minHeight="0dp"
        app:layout_constraintTop_toBottomOf="@id/btnRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Brújula (ocupa todo el espacio central) ── -->
    <com.example.ar.ui.compass.CompassView
        android:id="@+id/compass"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedSat"
        app:layout_constraintBottom_toTopOf="@id/infoPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Panel inferior: 3 cards con valores grandes ── -->
    <LinearLayout
        android:id="@+id/infoPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Azimut -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_info_card"
            android:layout_marginEnd="5dp"
            android:padding="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bearing_to_target"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_gravity="center_horizontal"/>
            <TextView
                android:id="@+id/txtBearing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/accent_cyan"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"/>
        </LinearLayout>

        <!-- Elevación -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_info_card"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:padding="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elevation_label"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_gravity="center_horizontal"/>
            <TextView
                android:id="@+id/txtElevation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="@color/accent_red"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"/>
        </LinearLayout>

        <!-- Distancia -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_info_card"
            android:layout_marginStart="5dp"
            android:padding="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/distance_to_target"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_gravity="center_horizontal"/>
            <TextView
                android:id="@+id/txtDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/accent_amber"
                android:textSize="32sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:gravity="center_horizontal"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="12sp"
                app:autoSizeMaxTextSize="32sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
