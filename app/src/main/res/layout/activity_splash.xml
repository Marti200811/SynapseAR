<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Círculo de pulso (animado programáticamente) -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_pulse_ring"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/splashIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.5"/>

    <!-- Ícono de señal -->
    <ImageView
        android:id="@+id/splashIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"
        android:alpha="0"
        android:scaleX="0.4"
        android:scaleY="0.4"
        app:layout_constraintTop_toBottomOf="@id/pulseRing"
        app:layout_constraintBottom_toTopOf="@id/splashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="24dp"/>

    <!-- Nombre de la app -->
    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SYNAPSE AR"
        android:textColor="#00E5FF"
        android:textSize="38sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:alpha="0"
        android:translationY="40dp"
        app:layout_constraintTop_toBottomOf="@id/splashIcon"
        app:layout_constraintBottom_toTopOf="@id/splashDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

    <!-- Línea divisora -->
    <View
        android:id="@+id/splashDivider"
        android:layout_width="0dp"
        android:layout_height="1.5dp"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:background="#00E5FF"
        android:alpha="0"
        android:scaleX="0"
        app:layout_constraintTop_toBottomOf="@id/splashTitle"
        app:layout_constraintBottom_toTopOf="@id/splashCompany"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="14dp"/>

    <!-- Nombre de la empresa -->
    <TextView
        android:id="@+id/splashCompany"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VECTRIX LABS"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:letterSpacing="0.28"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/splashDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.42"/>

    <!-- Versión abajo del todo -->
    <TextView
        android:id="@+id/splashVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textColor="#33FFFFFF"
        android:textSize="11sp"
        android:alpha="0"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
