<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_panel"
    android:padding="28dp">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/calibration_title"
        android:textColor="@color/accent_cyan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Subtítulo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/calibration_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Ícono animado (figura-8) -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/calibIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_splash_signal"
            android:tint="@color/accent_cyan"
            android:contentDescription="@string/calibration_icon_desc"/>
    </FrameLayout>

    <!-- Instrucciones -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/calibration_step1"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:drawablePadding="8dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/calibration_step2"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:drawablePadding="8dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/calibration_step3"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="12dp"/>

</LinearLayout>
