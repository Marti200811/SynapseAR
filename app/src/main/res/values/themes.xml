<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SynapseAR" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorOnPrimary">@color/bg_deep</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
    </style>

    <!-- Overlay para dialogs: fondo oscuro, texto claro -->
    <style name="ThemeOverlay.SynapseAR.Dialog" parent="ThemeOverlay.Material3">
        <item name="colorSurface">@color/bg_panel</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="android:colorBackground">@color/bg_panel</item>
    </style>

    <!-- Tema para la Splash Screen del sistema: negro puro, sin ícono, imperceptible -->
    <style name="Theme.SynapseAR.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/bg_splash_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">#000000</item>
        <item name="postSplashScreenTheme">@style/Theme.SynapseAR</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>