# ─────────────────────────────────────────────────────────────────────────
# PLANTILLA de credenciales de firma de release.
#
# 1. Copiá este archivo y renombrá la copia a:  keystore.properties
# 2. Completá los valores con TUS datos reales (los que elegiste al crear el .jks)
# 3. NUNCA subas keystore.properties a Git (ya está en .gitignore)
#
# Este .example SÍ se puede subir: no contiene secretos.
# ─────────────────────────────────────────────────────────────────────────

# Ruta al archivo keystore (.jks). Puede ser absoluta o relativa a la carpeta app/.
# Ejemplo absoluto (recomendado):
storeFile=C:/Users/rodolfo.diaz/keys/synapsear-release.jks

# Password del keystore (el "store password")
storePassword=CAMBIAR_POR_TU_PASSWORD

# Alias de la clave dentro del keystore
keyAlias=synapsear

# Password de la clave (el "key password"; suele ser el mismo que el del store)
keyPassword=CAMBIAR_POR_TU_PASSWORD
